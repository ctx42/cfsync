{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "cfsync base (strict, composite, declaration-only)",
  "compilerOptions": {
    // Strictness — maximum type safety.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    // Module system — modern ESM, bundler-resolved.
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    // Output — project references emit declarations only; bundlers (esbuild,
    // bun) produce the runtime JS, so tsc never writes .js here.
    "target": "ES2022",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "sourceMap": true,

    // Performance.
    "skipLibCheck": true
  }
}
