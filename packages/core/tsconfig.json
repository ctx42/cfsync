{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist/types",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    // Runtime-neutral: no DOM, no node globals. The import-boundary test
    // (test/boundary.test.ts) is the enforced gate; this lib set makes leaks
    // fail typecheck too.
    "lib": ["ES2022"],
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "test/**"]
}
