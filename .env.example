# cfsync environment file.
#
# Copy this file to ".env" and fill in the values below:
#
#     cp .env.example .env
#
# cfsync reads "./.env" by default; use --env to point it at a different path.
# Values are read from the process environment first; ".env" only fills in
# variables that are not already exported, so an exported value always wins.
# The working ".env" is git-ignored so credentials are never committed.
#
# The file has two independent sections. The CFSYNC_* variables configure
# everyday runs. The CFSYNC_TEST_* variables configure the live integration
# tests and never touch the Site your everyday runs point at.

# --- Production ------------------------------------------------------------
#
# The Site credentials read by every command. host, account, and token must
# not appear in .cfsync.yaml; they come from here or the environment.

# Base URL of the Atlassian Site, https://<id>.atlassian.net.
CFSYNC_HOST=https://your-site.atlassian.net

# Atlassian account email; the Basic Auth username.
CFSYNC_ACCOUNT=you@example.com

# Atlassian API token; the Basic Auth password. Create one at
# https://id.atlassian.com/manage-profile/security/api-tokens.
CFSYNC_TOKEN=your-api-token

# Directory the downloaded pages are written to. The --work-dir flag overrides
# it. A relative value is resolved against the directory of the config file.
CFSYNC_WORK_DIR=pages

# --- Live tests ------------------------------------------------------------
#
# Used only by `go test -tags confluence ./pkg/cfsync/`. The tests skip unless
# CFSYNC_TEST_HOST, CFSYNC_TEST_ACCOUNT, CFSYNC_TEST_TOKEN, and CFSYNC_TEST_SPACE
# are all set.

# Base URL of the Atlassian Site, https://<id>.atlassian.net.
CFSYNC_TEST_HOST=https://your-site.atlassian.net

# Atlassian account email; the Basic Auth username.
CFSYNC_TEST_ACCOUNT=you@example.com

# Atlassian API token; the Basic Auth password. Create one at
# https://id.atlassian.com/manage-profile/security/api-tokens.
CFSYNC_TEST_TOKEN=your-api-token

# Space key the mutating tests create and delete throwaway pages in. Use a
# throwaway space you own — the tests write to it.
CFSYNC_TEST_SPACE=TEST

# Optional parent folder id under CFSYNC_TEST_SPACE to keep test pages tidy.
# Leave empty to create pages at the space root.
CFSYNC_TEST_FOLDER=

# Optional comma-separated page ids for the read-only Test_live_explore probe.
# Leave empty to skip that test.
CFSYNC_TEST_EXPLORE_PAGES=
