# .env — secrets and the sync root (never commit this).
#
# Copy this file to `.env` beside your `.cfsync.yaml` and fill in the values.
# cfsync reads `./.env` by default; use `--env <path>` for another location.
# A value already exported in the environment wins over the one set here.

# Atlassian Site subdomain — just the part before .atlassian.net.
# For https://your-site.atlassian.net this is "your-site".
CFSYNC_SITE=your-site

# Atlassian account email; the Basic Auth username.
CFSYNC_ACCOUNT=you@example.com

# Atlassian API token; the Basic Auth password.
# Create one at https://id.atlassian.com/manage-profile/security/api-tokens
CFSYNC_TOKEN=your-api-token

# Folder every mapped destination resolves under (the vault or repo root).
# A relative path is resolved against the config file's directory; `.` is common.
CFSYNC_ROOT=/absolute/path/to/your/vault
