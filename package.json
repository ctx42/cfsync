{
  "name": "cfsync",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Confluence ↔ Obsidian sync: Obsidian plugin + standalone CLI (TypeScript rewrite of cfsync).",
  "license": "MIT",
  "author": "Rafal Zajac",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -b",
    "typecheck:clean": "tsc -b --clean",
    "typecheck:test": "bun run --filter '@cfsync/*' typecheck:test",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build": "bun run --filter '@cfsync/obsidian-plugin' build && bun run --filter '@cfsync/cli' build",
    "check": "bun run typecheck && bun run typecheck:test && bun run lint && bun run test",
    "install:cli": "./scripts/install.sh",
    "deploy:plugin": "bash packages/obsidian-plugin/scripts/deploy-local.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "msw": "^2.15.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "yaml": "^2.9.0"
  }
}
